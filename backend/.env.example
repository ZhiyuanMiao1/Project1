# Server
PORT=5000
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRES_IN=2h

# CORS (comma-separated allowlist; localhost is allowed by default)
# CORS_ORIGIN=http://localhost:3000

# Cookies (set true only when serving over HTTPS)
# COOKIE_SECURE=false

# MySQL Database (阿里云 RDS)
DB_HOST=rm-xxxxxxxxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306       # 数据库端口（MySQL 默认 3306）
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=project1

# Aliyun OSS (direct upload policy + signed download)
OSS_REGION=cn-hongkong
OSS_BUCKET=your_bucket
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# Aliyun RTC
ALIYUN_RTC_APP_ID=
ALIYUN_RTC_APP_KEY=

# PayPal
# PAYPAL_ENV=sandbox|live (default: sandbox)
PAYPAL_ENV=sandbox
# Optional override for API base, e.g. https://api-m.paypal.com
# PAYPAL_API_BASE=

# Sandbox credentials
PAYPAL_SANDBOX_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_SANDBOX_CLIENT_SECRET=your_paypal_sandbox_client_secret

# Live credentials (required when PAYPAL_ENV=live)
PAYPAL_LIVE_CLIENT_ID=your_paypal_live_client_id
PAYPAL_LIVE_CLIENT_SECRET=your_paypal_live_client_secret

# Aliyun DirectMail SMTP
MAIL_PROVIDER=aliyun_directmail_smtp
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=no-reply@example.com
MAIL_PASS=your_smtp_password
MAIL_FROM="Mentory <no-reply@example.com>"

# Email verification
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRES_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5
